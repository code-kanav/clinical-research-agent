# Model provider: "anthropic" | "gemini" | "vertexai"
LLM_PROVIDER=gemini

# Google Gemini API — get key at aistudio.google.com (required when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-pro
GEMINI_JUDGE_MODEL=gemini-1.5-flash   # cheaper model used for eval judge calls

# Anthropic (required when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Vertex AI (required when LLM_PROVIDER=vertexai; install vertex extras first)
# VERTEX_PROJECT_ID=your-gcp-project
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-1.5-pro

# Search APIs
NCBI_API_KEY=                  # optional; raises rate limit from 3 to 10 req/s
SEMANTIC_SCHOLAR_API_KEY=      # optional; raises rate limit significantly

# LangSmith tracing (optional)
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=clinical-research-agent

# Cache
CACHE_DIR=.cache
CACHE_TTL_SECONDS=604800       # 7 days; set to 0 to disable

# Eval
JUDGE_MODEL=claude-haiku-4-5-20251001
