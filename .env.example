# Model provider: "vertex" | "gemini" | "anthropic"
LLM_PROVIDER=vertex

# Vertex AI — default provider, uses Application Default Credentials (ADC)
# Setup: gcloud auth application-default login
# Project must have billing enabled and Vertex AI API enabled
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=us-central1

# Google Gemini AI Studio (required when LLM_PROVIDER=gemini)
# GOOGLE_API_KEY=AIzaSy...

# Anthropic (required when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Search APIs (both optional; raise rate limits when set)
NCBI_API_KEY=                  # raises PubMed from 3 to 10 req/s
SEMANTIC_SCHOLAR_API_KEY=      # raises S2 rate limit significantly

# LangSmith tracing (optional)
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=clinical-research-agent

# Cache
CACHE_DIR=.cache
CACHE_TTL_SECONDS=604800       # 7 days; set to 0 to disable

# Eval judge model (defaults to same model as LLM_PROVIDER)
# JUDGE_MODEL=gemini-2.5-flash
